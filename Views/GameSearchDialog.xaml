<Window x:Class="BackloggdStatus.Views.GameSearchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Link to Backloggd"
        Height="480" Width="600"
        MinHeight="300" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding SearchTitle}"
                   FontWeight="Bold"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"/>

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding SearchResults}"
                 SelectedItem="{Binding SelectedResult}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 BorderThickness="1">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="4"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <DockPanel Margin="4">
                        <Border DockPanel.Dock="Left"
                                Width="50" Height="75"
                                Background="#222"
                                Margin="0,0,10,0">
                            <Image Source="{Binding ThumbnailUrl, IsAsync=True}"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Year}"
                                       FontSize="11"
                                       Opacity="0.6"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <DockPanel Grid.Row="2" Margin="0,10,0,0" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left"
                       Text="{Binding ResultCountText}"
                       VerticalAlignment="Center"
                       Opacity="0.6"/>
            <Button DockPanel.Dock="Right"
                    Content="Cancel"
                    Width="80"
                    Margin="8,0,0,0"
                    IsCancel="True"
                    Click="Cancel_Click"/>
            <Button DockPanel.Dock="Right"
                    Content="Link"
                    Width="80"
                    IsDefault="True"
                    IsEnabled="{Binding HasSelection}"
                    Click="Confirm_Click"/>
        </DockPanel>
    </Grid>
</Window>
